//@version=4
study(title="💰ARPS Advanced Synergistic Oscillators & Filters💰", shorttitle="💰ARPS Advanced Synergistic Oscillators & Filters💰", overlay=false)

// ************************************************************************************
//--------------------------- Stochastic Momentum Index -----------------------------//

ShowSMI = input(false, title="Show Stochastic Momentum Index")

a = 10		//defval=10, "Percent K Length"
b = 3		//defval=3, "Percent D Length"
ob = 40		//defval=40, "Overbought"
os = -40	//defval=-40, "Oversold"

// Range Calculation
ll = lowest(low, a)
hh = highest(high, a)
diff = hh - ll
rdiff = close - (hh + ll) / 2

avgrel = ema(ema(rdiff, b), b)
avgdiff = ema(ema(diff, b), b)
// SMI calculations
SMI = avgdiff != 0 ? avgrel / (avgdiff / 2) * 100 : 0
SMIsignal = ema(SMI, b)
emasignal = ema(SMI, 10)

h0 = hline(40, editable=false)
h1 = hline(-40, editable=false)

//Color Definition for Stochastic Line
//col = SMI >= 40 ? green : SMI <= -40 ? red : black

plot(ShowSMI ? SMIsignal : na, title="Stochastic", style=plot.style_line, color=color.green, linewidth=2, editable=false)

plot(ShowSMI ? emasignal : na, title="EMA", style=plot.style_line, color=color.red, linewidth=2, editable=false)

level_40 = 40
level_40smi = SMIsignal > level_40 ? SMIsignal : level_40

level_m40 = -40
level_m40smi = SMIsignal < level_m40 ? SMIsignal : level_m40

p1 = plot(ShowSMI ? level_40 : na, editable=false)
p2 = plot(ShowSMI ? level_40smi : na, editable=false)

p3 = plot(ShowSMI ? level_m40 : na, editable=false)
p4 = plot(ShowSMI ? level_m40smi : na, editable=false)


ShowSMIfillTransp = ShowSMI ? 50 : 0
smi_color = SMIsignal > emasignal ? color.green : color.red

fill(p1, p2, color=color.red, transp=40, title='OverSold', transp=ShowSMIfillTransp, editable=false)
fill(p3, p4, color=color.green, transp=40, title='OverBought', transp=ShowSMIfillTransp, editable=false)
plot(ShowSMI and cross(SMIsignal, emasignal) ? SMIsignal : na, title="SMI Cross", style=plot.style_cross, linewidth=3, color=smi_color, transp=0, editable=false)


// ************************************************************************************
//------------------------------------- MACD ----------------------------------------//

ShowMACD = input(false, title="Show MACD")

source = close
useCurrentRes = true	//defval=true, title="Use Current Chart Resolution?"
resCustom = 60		//title="Use Different Timeframe? Uncheck Box Above", type=input.resolution, defval="60"
smd = true		//defval=true, title="Show MacD & Signal Line? Also Turn Off Dots Below", type=input.bool
sd = true		//defval=true, title="Show Dots When MacD Crosses Signal Line?", type=input.bool
sh = true		//defval=true, title="Show Histogram?", type=input.bool
macd_colorChange = true		//defval=true, title="Change MacD Line Color-Signal Line Cross?", type=input.bool
hist_colorChange = true		//defval=true, title="MacD Histogram 4 Colors?", type=input.bool

res = timeframe.period

fastLength = 12		//defval=12, minval=1
slowLength = 26		//defval=26, minval=1
signalLength = 9	//defval=9, minval=1

fastMA = ema(source, fastLength)
slowMA = ema(source, slowLength)

macd = fastMA - slowMA
signal = sma(macd, signalLength)
hist = macd - signal

outMacD = macd //security(tickerid, res, macd)
outSignal = signal //security(tickerid, res, signal)
outHist = hist  //security(tickerid, res, hist)

histA_IsUp = outHist >= outHist[1] and outHist > 0
histA_IsDown = outHist < outHist[1] and outHist > 0
histB_IsDown = outHist < outHist[1] and outHist <= 0
histB_IsUp = outHist >= outHist[1] and outHist <= 0

//MacD Color Definitions
macd_IsAbove = outMacD > outSignal
macd_IsBelow = outMacD <= outSignal

plot_color = hist_colorChange ? histA_IsUp ? #006400 : 
   histA_IsDown ? color.lime : histB_IsDown ? #b62c2c : histB_IsUp ? color.red : na : 
   na
macd_color = macd_colorChange ? macd_IsAbove ? #008000 : #c60000 : color.red
signal_color = macd_colorChange ? macd_IsAbove ? color.blue : color.blue : color.blue

circleYPosition = outSignal

plot(ShowMACD and smd and outMacD ? outMacD : na, title="MACD", color=macd_color, linewidth=3, transp=0, editable=false)
plot(ShowMACD and smd and outSignal ? outSignal : na, title="Signal Line", color=color.black, style=plot.style_line, linewidth=1, transp=20, editable=false)
plot(ShowMACD and sh and outHist ? outHist : na, title="Histogram", color=plot_color, style=plot.style_area, linewidth=2, transp=20, editable=false)
plot(ShowMACD and sd and cross(macd, signal) ? macd : na, title="MACD vs Signal Cross", style=plot.style_cross, linewidth=3, color=macd_color, transp=0, editable=false)
//hline(0, '0 Line', linestyle=solid, linewidth=2, color=white)


// ************************************************************************************
