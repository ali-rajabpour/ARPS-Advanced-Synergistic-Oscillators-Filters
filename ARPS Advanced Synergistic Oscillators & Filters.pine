nm79=79<=length ? (nm78+(1 + 78) * src[78]) : nm78, dm79=79<=length ? dm78+src[78] : dm78
nm80=80<=length ? (nm79+(1 + 79) * src[79]) : nm79, dm80=80<=length ? dm79+src[79] : dm79
nm81=81<=length ? (nm80+(1 + 80) * src[80]) : nm80, dm81=81<=length ? dm80+src[80] : dm80
nm82=82<=length ? (nm81+(1 + 81) * src[81]) : nm81, dm82=82<=length ? dm81+src[81] : dm81
nm83=83<=length ? (nm82+(1 + 82) * src[82]) : nm82, dm83=83<=length ? dm82+src[82] : dm82
nm84=84<=length ? (nm83+(1 + 83) * src[83]) : nm83, dm84=84<=length ? dm83+src[83] : dm83
nm85=85<=length ? (nm84+(1 + 84) * src[84]) : nm84, dm85=85<=length ? dm84+src[84] : dm84
nm86=86<=length ? (nm85+(1 + 85) * src[85]) : nm85, dm86=86<=length ? dm85+src[85] : dm85
nm87=87<=length ? (nm86+(1 + 86) * src[86]) : nm86, dm87=87<=length ? dm86+src[86] : dm86
nm88=88<=length ? (nm87+(1 + 87) * src[87]) : nm87, dm88=88<=length ? dm87+src[87] : dm87
nm89=89<=length ? (nm88+(1 + 88) * src[88]) : nm88, dm89=89<=length ? dm88+src[88] : dm88
nm90=90<=length ? (nm89+(1 + 89) * src[89]) : nm89, dm90=90<=length ? dm89+src[89] : dm89
nm91=91<=length ? (nm90+(1 + 90) * src[90]) : nm90, dm91=91<=length ? dm90+src[90] : dm90
nm92=92<=length ? (nm91+(1 + 91) * src[91]) : nm91, dm92=92<=length ? dm91+src[91] : dm91
nm93=93<=length ? (nm92+(1 + 92) * src[92]) : nm92, dm93=93<=length ? dm92+src[92] : dm92
nm94=94<=length ? (nm93+(1 + 93) * src[93]) : nm93, dm94=94<=length ? dm93+src[93] : dm93
nm95=95<=length ? (nm94+(1 + 94) * src[94]) : nm94, dm95=95<=length ? dm94+src[94] : dm94
nm96=96<=length ? (nm95+(1 + 95) * src[95]) : nm95, dm96=96<=length ? dm95+src[95] : dm95
nm97=97<=length ? (nm96+(1 + 96) * src[96]) : nm96, dm97=97<=length ? dm96+src[96] : dm96
nm98=98<=length ? (nm97+(1 + 97) * src[97]) : nm97, dm98=98<=length ? dm97+src[97] : dm97
nm99=99<=length ? (nm98+(1 + 98) * src[98]) : nm98, dm99=99<=length ? dm98+src[98] : dm98
nm100=100<=length ? (nm99+(1 + 99) * src[99]) : nm99, dm100=100<=length ? dm99+src[99] : dm99
nm=nm100, dm=dm100
cg = iff(dm != 0, -nm/dm + (length + 1) / 2.0, 0)
maxc = highest(cg, length)
minc = lowest(cg, length)
v1 = iff(maxc != minc, (cg - minc) / (maxc - minc), 0)
v2_ = (4*v1 + 3*v1[1] + 2*v1[2] + v1[3]) / 10.0
v2 = 2*(v2_ - 0.5)
t = ( 0.96 * ( ( v2[1]) + 0.02 ) )
duml=plot(ShowESCGO and fr?(v2>t?v2:t):na, style=plot.style_circles, linewidth=0, color=color.gray, title="Dummy", editable=false)
cmil=plot(ShowESCGO ? v2 : na, title="StochCGOsc", color=color.red, editable=false)
tl=plot(ShowESCGO ? t : na, title="Trigger",color=color.green, editable=false)
plot(0, title="ZeroLine", color=color.gray, editable=false) 
u1=abs(lvls),l1=abs(lvls)*-1.0
plot(u1,title="Level+",color=color.gray, editable=false) 
plot(l1,title="Level-",color=color.gray, editable=false)
ESCGOfillTransp = ShowESCGO ? 50 : 0
fill(cmil, duml, color=color.red, transp=ESCGOfillTransp, title="NegativeFill", editable=false)
fill(tl, duml, color=color.lime, transp=ESCGOfillTransp, title="PositiveFill", editable=false)

escgo_long = (v2>v2[1] and v2[1]<v2[2]) or (v2>u1 and v2[1]<l1[1])
escgo_short = (v2<v2[1] and v2[1]>v2[2]) or (v2<l1 and v2[1]>u1[1])

//ebc=input(false, title="Color bars?")
//bc=ebc?(v2>v2[1]?(v2>0?color.lime:color.green):v2<v2[1]?(v2>0?color.orange:color.red):(v2>u1?color.lime:v2<l1?color.red:color.gray)):na
//barcolor(bc)

// ************************************************************************************
//--------------------------- Ehlers Smoothed Stochastic ----------------------------//

ShowESS = input(true, title="Show Ehlers Smoothed Stochastic")

PI = 3.14159265359
applyDoubleSmoothing = false	//defval=false, type=input.bool
ESSlength = 14		//defval=14, title="Stoch Length"
lengthMA = 3	//defval=3, title="Stoch MA Length"
over_bought = .8	//defval=.8
over_sold = .2	//defval=.2
ESSsrc = close
roofingBandUpper = 48	//defval=48
roofingBandLower = 10	//defval=10

EhlersSuperSmootherFilter(price, lower) =>
    filt = 0.0
    a1 = exp(-PI * sqrt(2) / lower)
    coeff2 = 2 * a1 * cos(sqrt(2) * PI / lower)
    coeff3 = -pow(a1, 2)
    coeff1 = 1 - coeff2 - coeff3
    filt := coeff1 * (price + nz(price[1])) / 2 + coeff2 * nz(filt[1]) + 
       coeff3 * nz(filt[2])
    filt

EhlersRoofingFilter(price, smoothed, upper, lower) =>
    highpass = 0.0
    alpha1 = (cos(sqrt(2) * PI / upper) + sin(sqrt(2) * PI / upper) - 1) / 
       cos(sqrt(2) * PI / upper)
    highpass := pow(1 - alpha1 / 2, 2) * (price - 2 * nz(price[1]) + nz(price[2])) + 
       2 * (1 - alpha1) * nz(highpass[1]) - pow(1 - alpha1, 2) * nz(highpass[2])
    EhlersSuperSmootherFilter__1 = EhlersSuperSmootherFilter(highpass, lower)
    smoothed ? EhlersSuperSmootherFilter__1 : highpass

EhlersStochastic(price, ESSlength, applyEhlerSmoothing, roofingBandUpper, roofingBandLower) =>
    filt = EhlersRoofingFilter(price, applyEhlerSmoothing, roofingBandUpper, roofingBandLower)
    highestP = highest(filt, ESSlength)
    lowestP = lowest(filt, ESSlength)
    iff(highestP - lowestP != 0, (filt - lowestP) / (highestP - lowestP), 0)


stoch = EhlersSuperSmootherFilter(EhlersStochastic(ESSsrc, ESSlength, applyDoubleSmoothing, roofingBandUpper, roofingBandLower), roofingBandLower)
//hline(over_bought)
//hline(over_sold)
//hline((over_bought + over_sold) / 2)
EssColor = stoch > sma(stoch, lengthMA) ? color.green : color.red
CxColor = stoch > sma(stoch, lengthMA) ? color.green : color.red
plot(ShowESS ? sma(stoch, lengthMA) : na, color=color.black, linewidth=1, transp=0, editable=false)
plot(ShowESS ? stoch : na, color=EssColor, linewidth=3, transp=0, editable=false)
plot(ShowESS and cross(sma(stoch, lengthMA), stoch) ? stoch : na, style = plot.style_cross, color=CxColor, linewidth = 4, editable=false, transp=0, editable=false)

// ***********************************************************************************
//------------------------------------ Alerts --------------------------------------//
alertcondition(crossover(macd, signal) and macd < outHist, title="MACD Strong Long Entry", message="MACD Strong Long Entry")
alertcondition(crossover(macd, signal), title="MACD Weak Long Entry", message="MACD Weak Long Entry")
alertcondition(crossover(signal, macd) and macd > outHist, title="MACD Strong Short Entry", message="MACD Strong Short Entry")
alertcondition(crossover(signal, macd), title="MACD Weak Short Entry", message="MACD Weak Short Entry")

alertcondition(escgo_long, title="ESCGO Long Entry", message="ESCGO Long Entry")
alertcondition(escgo_short, title="ESCGO Short Entry", message="ESCGO Short Entry")

alertcondition(crossover(stoch, sma(stoch, lengthMA)), title="Ehlers Smoothed Stoch Long Entry", message="Ehlers Smoothed Stoch Long Entry")
alertcondition(crossover(sma(stoch, lengthMA), stoch), title="Ehlers Smoothed Stoch Short Entry", message="Ehlers Smoothed Stoch Short Entry")

alertcondition(crossover(stoch, sma(stoch, lengthMA)) and escgo_long, title="ES-Stoch & ESCGO Strong Long Entry", message="ES-Stoch & ESCGO Strong Long Entry")
alertcondition(crossover(sma(stoch, lengthMA), stoch) and escgo_short, title="ES-Stoch & ESCGO Strong Short Entry", message="ES-Stoch & ESCGO Strong Short Entry")
